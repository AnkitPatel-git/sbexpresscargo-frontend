  amount       Decimal?           @db.Decimal(14, 4)
  fuelApply    Boolean            @default(false) @map("fuel_apply") @db.TinyInt
  fuelAmount   Decimal?           @map("fuel_amount") @db.Decimal(14, 4)
  taxApply     Boolean            @default(false) @map("tax_apply") @db.TinyInt
  taxOnFuel    Boolean            @default(false) @map("tax_on_fuel") @db.TinyInt
