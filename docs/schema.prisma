  @@map("shipment_receipts")
}

// Shipment receipt line (Receipt No, Date, Amount, User, Type, Reference, Bank).
model ShipmentReceiptLine {
  id          Int             @id @default(autoincrement())
  receiptId   Int             @map("receipt_id")
  shipmentId  Int             @map("shipment_id")
  receiptNo   String?         @map("receipt_no") @db.VarChar(64)
  receiptDate DateTime?       @map("receipt_date") @db.Date
  amount      Decimal?        @db.Decimal(14, 2)
  userId      Int?            @map("user_id")
  receiptType String?         @map("receipt_type") @db.VarChar(64)
  referenceNo String?         @map("reference_no") @db.VarChar(64)
  bankId      Int?            @map("bank_id")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.Timestamp(6)
  createdById Int?            @map("created_by_id")
  updatedById Int?            @map("updated_by_id")
  deletedAt   DateTime?       @map("deleted_at") @db.DateTime(6)
  deletedById Int?            @map("deleted_by_id")
  receipt     ShipmentReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  shipment    Shipment        @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  bank        Bank?           @relation("ReceiptLineBank", fields: [bankId], references: [id], onDelete: SetNull)

  @@index([receiptId])
  @@index([shipmentId])
  @@index([receiptId, shipmentId])
  @@index([receiptId, createdAt])
  @@map("shipment_receipt_lines")
}

// Manifest scan header (transaction-level manifest).
// Active uniqueness enforced via generated column active_key (MySQL 8.0+).
// Soft-deleted rows have active_key = NULL; MySQL allows multiple NULLs in unique index.
model Manifest {
  id              Int            @id @default(autoincrement())
  manifestNo      String         @map("manifest_no") @db.VarChar(64)
  masterAwbNo     String?        @map("master_awb_no") @db.VarChar(64)
  manifestAt      DateTime       @map("manifest_at") @db.DateTime(6)
  status          ManifestStatus @default(CREATED)
  version         Int            @default(1)
  location        String?        @db.VarChar(100)
  serviceCenterId Int?           @map("service_center_id")
  connectStation  String?        @map("connect_station") @db.VarChar(100)
  vendorId        Int?           @map("vendor_id")
  productId       Int?           @map("product_id")
  vehicleId       Int?           @map("vehicle_id")
  format          String?        @db.VarChar(64)
  singleLine      Boolean        @default(false) @map("single_line") @db.TinyInt
  pdfType         String?        @map("pdf_type") @db.VarChar(64)
  accountNo       String?        @map("account_no") @db.VarChar(64)
  department      String?        @db.VarChar(100)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamp(6)
  createdById     Int?           @map("created_by_id")
  updatedById     Int?           @map("updated_by_id")
  deletedAt       DateTime?      @map("deleted_at") @db.DateTime(6)
  deletedById     Int?           @map("deleted_by_id")
  activeKey       String?        @map("active_key") @db.VarChar(64)

  items             ManifestItem[]
  manifestShipments ManifestShipment[]
  progresses        ManifestProgress[]
  inscans           ManifestInscan[]
  logs              ManifestLog[]

  serviceCenter ServiceCenter? @relation(fields: [serviceCenterId], references: [id])
  vehicle       Vehicle?       @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@unique([activeKey])
  @@map("manifests")
}

// Manifest-Shipment link: one shipment belongs to at most one manifest.
// Active uniqueness enforced via generated column active_key (MySQL 8.0+).
// Soft-deleted rows have active_key = NULL; MySQL allows multiple NULLs in unique index.
model ManifestShipment {
  id          Int       @id @default(autoincrement())
  manifestId  Int       @map("manifest_id")
  shipmentId  Int       @map("shipment_id")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(6)
  deletedById Int?      @map("deleted_by_id")
  activeKey   String?   @map("active_key") @db.VarChar(64)

  manifest Manifest @relation(fields: [manifestId], references: [id], onDelete: Cascade)
  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([activeKey])
  @@index([manifestId])
  @@index([manifestId, createdAt])
  @@index([shipmentId])
  @@map("manifest_shipments")
}

model ManifestLog {
  id          Int      @id @default(autoincrement())
  manifestId  Int      @map("manifest_id")
  message     String   @db.VarChar(1000)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  createdById Int?     @map("created_by_id")

  manifest Manifest @relation(fields: [manifestId], references: [id], onDelete: Cascade)

  @@index([manifestId, createdAt])
  @@map("manifest_logs")
}

// Manifest AWB rows (scan details, denormalized for export & print).
model ManifestItem {
  id              Int       @id @default(autoincrement())
  manifestId      Int       @map("manifest_id")
  bagNo           String?   @map("bag_no") @db.VarChar(64)
  forwardingNo    String?   @map("forwarding_no") @db.VarChar(64)
  awbNo           String    @map("awb_no") @db.VarChar(64)
  refNo           String?   @map("ref_no") @db.VarChar(64)
  crnMhbsNo       String?   @map("crn_mhbs_no") @db.VarChar(64)
  pieces          Int       @default(1)
  chargeWeight    Decimal?  @map("charge_weight") @db.Decimal(10, 3)
  bookDate        DateTime? @map("book_date") @db.Date
  origin          String?   @db.VarChar(100)
  destination     String?   @db.VarChar(100)
  code            String?   @db.VarChar(32)
  customer        String?   @db.VarChar(255)
  consignee       String?   @db.VarChar(255)
  instruction     String?   @db.VarChar(500)
  // Export/print helper fields (optional, copied from shipment & masters)
  content         String?   @db.VarChar(255)
  actlWeight      Decimal?  @map("actl_weight") @db.Decimal(10, 3)
  shipperName     String?   @map("shipper_name") @db.VarChar(255)
  shipperTelNo    String?   @map("shipper_tel_no") @db.VarChar(32)
  shipperAdd1     String?   @map("shipper_add1") @db.VarChar(255)
  orgCode         String?   @map("org_code") @db.VarChar(32)
  consigneeTelNo  String?   @map("consignee_tel_no") @db.VarChar(32)
  consigneeAdd1   String?   @map("consignee_add1") @db.VarChar(255)
  consigneeAdd2   String?   @map("consignee_add2") @db.VarChar(255)
  consigneeAdd3   String?   @map("consignee_add3") @db.VarChar(255)
  destinationCode String?   @map("destination_code") @db.VarChar(32)
  keydate2        DateTime? @db.Date
  vendorCode      String?   @map("vendor_code") @db.VarChar(32)
  prodName        String?   @map("prod_name") @db.VarChar(100)
  orgCountry      String?   @map("org_country") @db.VarChar(100)

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  // snapshotAt: set when manifest status transitions to CLOSED.
  // Service layer MUST populate all denormalized fields (shipperName, consigneeTelNo, etc.)
  // in the same transaction as the CLOSED transition. Null = manifest not yet closed/printed.
  snapshotAt  DateTime? @map("snapshot_at") @db.DateTime(6)
  createdById Int?      @map("created_by_id")
  updatedById Int?      @map("updated_by_id")
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(6)
  deletedById Int?      @map("deleted_by_id")

  manifest            Manifest             @relation(fields: [manifestId], references: [id], onDelete: Cascade)
  manifestInscanItems ManifestInscanItem[]

  @@index([manifestId])
  @@index([manifestId, createdAt])
  @@index([awbNo])
  @@map("manifest_items")
}

// Manifest progress rows.
model ManifestProgress {
  id              Int       @id @default(autoincrement())
  manifestId      Int       @map("manifest_id")
  bagNo           String?   @map("bag_no") @db.VarChar(64)
  progressedAt    DateTime  @map("progressed_at") @db.DateTime(6)
  serviceCenterId Int?      @map("service_center_id")
  exceptionId     Int?      @map("exception_id")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  createdById     Int?      @map("created_by_id")
  updatedById     Int?      @map("updated_by_id")
  deletedAt       DateTime? @map("deleted_at") @db.DateTime(6)
  deletedById     Int?      @map("deleted_by_id")

  manifest      Manifest       @relation(fields: [manifestId], references: [id], onDelete: Cascade)
  serviceCenter ServiceCenter? @relation(fields: [serviceCenterId], references: [id])
  exception     Exception?     @relation(fields: [exceptionId], references: [id])

  @@map("manifest_progresses")
}

// Manifest inscan: record of scanning in a bag/manifest at a service center (links to Manifest, ManifestItem, Shipment).
model ManifestInscan {
  id                 Int       @id @default(autoincrement())
  manifestId         Int?      @map("manifest_id")
  bagOrManifestAwbNo String?   @map("bag_or_manifest_awb_no") @db.VarChar(64)
  inscanAt           DateTime  @map("inscan_at") @db.DateTime(6)
  serviceCenterId    Int?      @map("service_center_id")
  bagNo              String?   @map("bag_no") @db.VarChar(64)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  createdById        Int?      @map("created_by_id")
  updatedById        Int?      @map("updated_by_id")
  deletedAt          DateTime? @map("deleted_at") @db.DateTime(6)
  deletedById        Int?      @map("deleted_by_id")

  manifest      Manifest?            @relation(fields: [manifestId], references: [id], onDelete: SetNull)
  serviceCenter ServiceCenter?       @relation(fields: [serviceCenterId], references: [id])
  items         ManifestInscanItem[]

  @@index([serviceCenterId, inscanAt])
  @@map("manifest_inscans")
}

// Manifest inscan detail: each AWB row (links to ManifestItem or Shipment when present).
model ManifestInscanItem {
  id               Int       @id @default(autoincrement())
  manifestInscanId Int       @map("manifest_inscan_id")
  manifestNo       String?   @map("manifest_no") @db.VarChar(64)
  bagNo            String?   @map("bag_no") @db.VarChar(64)
  awbNo            String    @map("awb_no") @db.VarChar(64)
  pieces           Int       @default(1)
  weight           Decimal?  @db.Decimal(10, 3)
  manifestItemId   Int?      @map("manifest_item_id")
  shipmentId       Int?      @map("shipment_id")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  createdById      Int?      @map("created_by_id")
  updatedById      Int?      @map("updated_by_id")
  deletedAt        DateTime? @map("deleted_at") @db.DateTime(6)
  deletedById      Int?      @map("deleted_by_id")

  manifestInscan ManifestInscan @relation(fields: [manifestInscanId], references: [id], onDelete: Cascade)
  manifestItem   ManifestItem?  @relation(fields: [manifestItemId], references: [id], onDelete: SetNull)
  shipment       Shipment?      @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  @@index([shipmentId])
  @@index([manifestItemId])
  @@map("manifest_inscan_items")
}

// DRS Scan (Delivery Run Sheet). Header: DRS No., Date, Time, Field Executive, Area, Service Center, Remark.
// Active uniqueness enforced via generated column active_key (MySQL 8.0+).
// Soft-deleted rows have active_key = NULL; MySQL allows multiple NULLs in unique index.
model DrsScan {
  id              Int       @id @default(autoincrement())
  drsNo           String    @map("drs_no") @db.VarChar(64)
  drsAt           DateTime  @map("drs_at") @db.DateTime(6)
  status          DrsStatus @default(CREATED)
  version         Int       @default(1)
  courierId       Int?      @map("courier_id")
  areaId          Int?      @map("area_id")
  serviceCenterId Int?      @map("service_center_id")
  remark          String?   @db.VarChar(500)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  createdById     Int?      @map("created_by_id")
  updatedById     Int?      @map("updated_by_id")
  deletedAt       DateTime? @map("deleted_at") @db.DateTime(6)
  deletedById     Int?      @map("deleted_by_id")
  activeKey       String?   @map("active_key") @db.VarChar(64)

  items DrsScanItem[]

  courier       Courier?       @relation(fields: [courierId], references: [id])
  serviceCenter ServiceCenter? @relation(fields: [serviceCenterId], references: [id])

  @@unique([activeKey])
  @@map("drs_scans")
}

// DRS Scan item: AWB line (links to Shipment when present).
model DrsScanItem {
  id          Int       @id @default(autoincrement())
  drsScanId   Int       @map("drs_scan_id")
  shipmentId  Int?      @map("shipment_id")
  awbNo       String    @map("awb_no") @db.VarChar(64)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  createdById Int?      @map("created_by_id")
  updatedById Int?      @map("updated_by_id")
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(6)
  deletedById Int?      @map("deleted_by_id")

  drsScan  DrsScan   @relation(fields: [drsScanId], references: [id], onDelete: Cascade)
  shipment Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  @@index([shipmentId])
  @@index([drsScanId])
  @@map("drs_scan_items")
}

// Event scan (Undelivered Received / Misrouted). Header: Scan Date, Time, Service Center, Event Type.
enum DrsStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
}

model EventScan {
  id              Int       @id @default(autoincrement())
  eventType       String    @map("event_type") @db.VarChar(32)
  scanAt          DateTime  @map("scan_at") @db.DateTime(6)
  serviceCenterId Int?      @map("service_center_id")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  createdById     Int?      @map("created_by_id")
  updatedById     Int?      @map("updated_by_id")
  deletedAt       DateTime? @map("deleted_at") @db.DateTime(6)
  deletedById     Int?      @map("deleted_by_id")

  items EventScanItem[]

  serviceCenter ServiceCenter? @relation(fields: [serviceCenterId], references: [id])

  @@index([serviceCenterId, scanAt])
  @@map("event_scans")
}

// Event scan item: AWB line (links to Shipment when present).
model EventScanItem {
  id          Int       @id @default(autoincrement())
  eventScanId Int       @map("event_scan_id")
  shipmentId  Int?      @map("shipment_id")
  awbNo       String    @map("awb_no") @db.VarChar(64)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  createdById Int?      @map("created_by_id")
  updatedById Int?      @map("updated_by_id")
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(6)
  deletedById Int?      @map("deleted_by_id")

  eventScan EventScan @relation(fields: [eventScanId], references: [id], onDelete: Cascade)
  shipment  Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  @@index([shipmentId])
  @@map("event_scan_items")
}

// Credit Note (receiptExpenses). Header: Note No, Credit Note seq, Date, Customer, Invoice Ref, Narration, GST, amounts.
// Active uniqueness enforced via generated column active_key (MySQL 8.0+).
// Soft-deleted rows have active_key = NULL; MySQL allows multiple NULLs in unique index.
model CreditNote {
  id              Int              @id @default(autoincrement())
  noteNo          String           @map("note_no") @db.VarChar(64)
  creditNoteNo    Int?             @map("credit_note_no") @db.Int
  cnDate          DateTime         @map("cn_date") @db.Date
  customerId      Int              @map("customer_id")
  invoiceRef      String?          @map("invoice_ref") @db.VarChar(128)
  narration       String?          @db.VarChar(500)
  gst             Boolean          @default(false) @db.TinyInt
  amount          Decimal?         @db.Decimal(14, 2)
  igst            Decimal?         @db.Decimal(14, 2)
  sgst            Decimal?         @db.Decimal(14, 2)
  cgst            Decimal?         @db.Decimal(14, 2)
  totalAmount     Decimal?         @map("total_amount") @db.Decimal(14, 2)
  grandTotal      Decimal?         @map("grand_total") @db.Decimal(14, 2)
  serviceCenterId Int?             @map("service_center_id")
  status          CreditNoteStatus @default(DRAFT)
  version         Int              @default(1)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamp(6)
  createdById     Int?             @map("created_by_id")
  updatedById     Int?             @map("updated_by_id")
  deletedAt       DateTime?        @map("deleted_at") @db.DateTime(6)
  deletedById     Int?             @map("deleted_by_id")
  activeKey       String?          @map("active_key") @db.VarChar(64)

  customer      Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  serviceCenter ServiceCenter?   @relation(fields: [serviceCenterId], references: [id])
  items         CreditNoteItem[]

  @@unique([activeKey])
  @@index([customerId, createdAt])
  @@index([serviceCenterId, createdAt])
  @@map("credit_notes")
}

// Credit Note line item (AWB-wise amounts and tax).
model CreditNoteItem {
  id           Int       @id @default(autoincrement())
  creditNoteId Int       @map("credit_note_id")
  // awbNo is a snapshot of AWB at credit note creation time (financial audit trail).
  // shipmentId is the live FK for integrity checks; nullable for manual adjustment lines.
  awbNo        String    @map("awb_no") @db.VarChar(64)
  shipmentId   Int?      @map("shipment_id")
  destination  String?   @db.VarChar(100)
  product      String?   @db.VarChar(100)
  weight       Decimal?  @db.Decimal(10, 3)
  pcs          Int?      @db.Int
  remark       String?   @db.VarChar(255)
  amount       Decimal?  @db.Decimal(14, 2)
  igst         Decimal?  @db.Decimal(14, 2)
  sgst         Decimal?  @db.Decimal(14, 2)
  cgst         Decimal?  @db.Decimal(14, 2)
  total        Decimal?  @db.Decimal(14, 2)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  createdById  Int?      @map("created_by_id")
  updatedById  Int?      @map("updated_by_id")
  deletedAt    DateTime? @map("deleted_at") @db.DateTime(6)
  deletedById  Int?      @map("deleted_by_id")

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  shipment   Shipment?  @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  @@index([shipmentId])
  @@map("credit_note_items")
}

// Customer Payment: register payments (date, paid date, amount, remark, customer, optional image, approved).
model CustomerPayment {
  id          Int       @id @default(autoincrement())
  date        DateTime  @db.Date
  paidDate    DateTime  @map("paid_date") @db.Date
  amount      Decimal   @db.Decimal(14, 2)
  remark      String?   @db.VarChar(500)
  invoiceNo   String?   @map("invoice_no") @db.VarChar(64)
  customerId  Int       @map("customer_id")
  approved    Boolean   @default(false) @db.TinyInt
  filePath    String?   @map("file_path") @db.VarChar(512)
  fileName    String?   @map("file_name") @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  createdById Int?      @map("created_by_id")
  updatedById Int?      @map("updated_by_id")
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(6)
  deletedById Int?      @map("deleted_by_id")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  invoice  Invoice? @relation(fields: [invoiceNo], references: [invoiceNo], onDelete: SetNull)

  @@index([invoiceNo])
  @@index([customerId, createdAt])
  @@map("customer_payments")
}

// Invoice (document). Generated from shipments; one per customer per period. Lock/unlock for finalise.
model Invoice {
  id              Int           @id @default(autoincrement())
  invoiceNo       String        @map("invoice_no") @db.VarChar(64)
  invoiceDate     DateTime      @map("invoice_date") @db.Date
  version         Int           @default(1)
  financialYear   String?       @map("financial_year") @db.VarChar(32)
  customerId      Int           @map("customer_id")
  fromDate        DateTime      @map("from_date") @db.Date
  toDate          DateTime      @map("to_date") @db.Date
  productType     ProductType?  @map("product_type")
  serviceCenterId Int?          @map("service_center_id")
  billingType     String?       @map("billing_type") @db.VarChar(64)
  registerType    RegisterType? @map("register_type")
  totalAmount     Decimal?      @map("total_amount") @db.Decimal(14, 2)
  igst            Decimal?      @db.Decimal(14, 2)
  cgst            Decimal?      @db.Decimal(14, 2)
  sgst            Decimal?      @db.Decimal(14, 2)
  grandTotal      Decimal?      @map("grand_total") @db.Decimal(14, 2)
  awbCount        Int           @default(0) @map("awb_count") @db.Int
  status          InvoiceStatus @default(DRAFT)
  emailSentAt     DateTime?     @map("email_sent_at") @db.DateTime(6)
  lockedAt        DateTime?     @map("locked_at") @db.DateTime(6)
  lockedById      Int?          @map("locked_by_id")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamp(6)
  createdById     Int?          @map("created_by_id")
  updatedById     Int?          @map("updated_by_id")
  deletedAt       DateTime?     @map("deleted_at") @db.DateTime(6)
  deletedById     Int?          @map("deleted_by_id")

  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  serviceCenter    ServiceCenter?    @relation(fields: [serviceCenterId], references: [id])
  createdBy        User?             @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  updatedBy        User?             @relation("InvoiceUpdatedBy", fields: [updatedById], references: [id])
  deletedBy        User?             @relation("InvoiceDeletedBy", fields: [deletedById], references: [id])
  lockLogs         InvoiceLockLog[]
  invoiceShipments InvoiceShipment[]
  customerPayments CustomerPayment[]

  @@unique([invoiceNo])
  @@index([customerId, createdAt])
  @@index([serviceCenterId, createdAt])
  @@index([status])
  @@map("invoices")
}

// Invoice-Shipment link: which shipments are included in an invoice.
model InvoiceShipment {
  id         Int @id @default(autoincrement())
  invoiceId  Int @map("invoice_id")
  shipmentId Int @map("shipment_id")

  invoice  Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([shipmentId])
  @@index([invoiceId])
  @@map("invoice_shipments")
}

// Invoice lock/unlock log for report (Lock/Unlock Invoice Log Report Type Wise).
model InvoiceLockLog {
  id              Int               @id @default(autoincrement())
  invoiceId       Int               @map("invoice_id")
  action          InvoiceLockAction
  serviceCenterId Int?              @map("service_center_id")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  createdById     Int?              @map("created_by_id")

  invoice       Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  serviceCenter ServiceCenter? @relation(fields: [serviceCenterId], references: [id])

  @@map("invoice_lock_logs")
}
